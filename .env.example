# Supabase / Neon — pooled connection for the app (Transaction pooler, port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection for Prisma migrations (NOT the pooler — use db.*.supabase.co)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Vercel Cron — set the same value in Vercel project env vars
CRON_SECRET="generate-a-long-random-string"

# Optional: Upstash Redis (future distributed lock / cache)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
