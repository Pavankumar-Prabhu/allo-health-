# Supabase / Neon — pooled connection for the app (Transaction pooler, port 6543)
# Host may be aws-0, aws-1, etc. — copy exactly from Supabase Connect dialog
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session pooler for Prisma migrations (IPv4-friendly)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# Vercel Cron — set the same value in Vercel project env vars
CRON_SECRET="generate-a-long-random-string"

# Optional: Upstash Redis (future distributed lock / cache)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
